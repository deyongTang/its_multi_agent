# ==================== AI 服务配置 ====================
# 硅基流动 API（与阿里百炼二选一，或同时配置）
SF_API_KEY=your_siliconflow_api_key_here
SF_BASE_URL=https://api.siliconflow.cn/v1

# 阿里百炼 API
AL_BAILIAN_API_KEY=your_aliyun_bailian_api_key_here
AL_BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ==================== 模型配置 ====================
MAIN_MODEL_NAME=Qwen/Qwen3-32B
SUB_MODEL_NAME=

# ==================== 数据库配置 ====================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=its_db

# ==================== Redis 配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==================== 外部服务配置 ====================
# 知识库服务（backend/knowledge 的地址）
KNOWLEDGE_BASE_URL=http://127.0.0.1:8001
KNOWLEDGE_BASE_TOKEN=

# 通义千问搜索服务（DashScope）
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 百度地图
BAIDUMAP_AK=your_baidumap_ak_here

# ==================== LangSmith 可观测性（可选）====================
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=ITS-MultiAgent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
