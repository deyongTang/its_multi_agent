# ==============================================================
# ITS 多智能体系统 - 环境变量配置模板
# 使用方法：复制本文件为 .env，填入真实配置值
# cp .env.example .env
# ==============================================================

# ==================== AI 服务配置（二选一）====================
# 【必填】至少配置一个 AI 服务，否则系统启动时会抛出 ValueError

# 方案一：硅基流动（SiliconFlow）
SF_API_KEY=your_siliconflow_api_key_here
SF_BASE_URL=https://api.siliconflow.cn/v1

# 方案二：阿里百炼（DashScope OpenAI 兼容模式）
# AL_BAILIAN_API_KEY=your_aliyun_bailian_api_key_here
# AL_BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ==================== 模型配置 ====================
# 主模型：负责核心业务推理（意图识别、槽位填充、最终回答生成）
MAIN_MODEL_NAME=Qwen/Qwen3-32B

# 子模型：负责轻量级辅助任务（意图分类、动态槽位判断）
# 留空则与主模型相同；推荐配置更快更便宜的模型以降低延迟和成本
SUB_MODEL_NAME=

# ==================== MySQL 数据库配置 ====================
# 存储服务站数据，供 service_station 意图查询使用
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=its_db
MYSQL_CHARSET=utf8mb4
MYSQL_CONNECT_TIMEOUT=10
MYSQL_MAX_CONNECTIONS=5

# ==================== Redis 配置 ====================
# 用于会话热缓存（TTL 24h）和分布式写锁
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==================== 外部服务配置 ====================

# 知识库平台（ITS Knowledge 子系统，用于 tech_issue 意图的 RAG 查询）
# 本地启动时默认地址为 http://127.0.0.1:8001
KNOWLEDGE_BASE_URL=http://127.0.0.1:8001
KNOWLEDGE_BASE_TOKEN=

# 通义千问 DashScope（用于 search_info 意图的联网搜索）
DASHSCOPE_API_KEY=your_dashscope_api_key_here
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# 百度地图（用于 poi_navigation 意图的路径规划，需申请 AK）
# 申请地址：https://lbsyun.baidu.com/apiconsole/key
BAIDUMAP_AK=your_baidu_map_ak_here

# ==================== LangSmith 可观测性（可选）====================
# 用于追踪 LangGraph 节点执行链路，生产环境推荐开启
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ITS-MultiAgent
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
