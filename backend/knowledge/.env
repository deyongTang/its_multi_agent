API_KEY=REDACTED_API_KEY
BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL=qwen2.5-32b-instruct
EMBEDDING_MODEL=text-embedding-v3
KNOWLEDGE_BASE_URL=https://iknow.lenovo.com.cn

# Database Config
DB_HOST=YOUR_SERVER_IP
DB_PORT=3306
DB_USER=root
DB_PASSWORD=REDACTED_PASSWORD
DB_NAME=its_knowledge

# Elasticsearch 配置
ES_HOST=YOUR_SERVER_IP
ES_PORT=9200
ES_SCHEME=http
ES_USERNAME=elastic
ES_PASSWORD=REDACTED_PASSWORD
ES_INDEX_NAME=its_knowledge_index
ES_VECTOR_DIMS=1024

# minio 对象存储配置
MINIO_ENDPOINT=YOUR_SERVER_IP:9000
MINIO_ACCESS_KEY=its_appkey
MINIO_SECRET_KEY=REDACTED_SECRET
MINIO_BUCKET=knowledge-base
MINIO_SECURE=false