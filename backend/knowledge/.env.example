# OpenAI API 配置（或兼容的 API，如阿里百炼）
API_KEY=your_openai_api_key_here
BASE_URL=https://api.openai.com/v1
MODEL=gpt-4
EMBEDDING_MODEL=text-embedding-3-small

# MySQL 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=its_knowledge

# 联想知识库 API
KNOWLEDGE_BASE_URL=https://iknow.lenovo.com.cn

# MinIO 对象存储配置
MINIO_ENDPOINT=your_minio_host_here:9000
MINIO_ACCESS_KEY=your_minio_access_key_here
MINIO_SECRET_KEY=your_minio_secret_key_here
MINIO_BUCKET=knowledge-base
MINIO_SECURE=false

# Elasticsearch 配置
ES_HOST=your_es_host_here
ES_PORT=9200
ES_SCHEME=http
ES_USERNAME=elastic
ES_PASSWORD=your_es_password_here
ES_INDEX_NAME=knowledge_index
ES_VECTOR_DIMS=1024

# 文本切分配置
CHUNK_SIZE=3000
CHUNK_OVERLAP=200

# 检索配置
TOP_ROUGH=50
TOP_FINAL=5

# Reranker 配置（硅基流动）
RERANKER_ENABLED=false
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
RERANKER_BASE_URL=https://api.siliconflow.cn/v1
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_N=50
RERANKER_TIMEOUT=10

# 动态阈值截断（方案三）
DYNAMIC_THRESHOLD_ENABLED=false
DYNAMIC_DROP_THRESHOLD=0.3
DYNAMIC_MIN_RESULTS=1

# Worker 配置
WORKER_BATCH_SIZE=10
WORKER_MAX_RETRY=3
WORKER_INTERVAL_SECONDS=30

# JWT 认证配置
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
